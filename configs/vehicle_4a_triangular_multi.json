        { "id": "SR", "sensor": "heat-sensor", "side": "right", "angle_offset": -0.3, "distance_from_center": 8 }
      ],
      "motors": [
        { "id": "ML", "side": "left", "max_speed": 80.0, "gain": 1.0, "base_voltage": 25.0 },
        { "id": "MR", "side": "right", "max_speed": 80.0, "gain": 1.0, "base_voltage": 25.0 }
