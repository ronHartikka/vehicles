{
  "environment": {
    "fields": [
      {
        "type": "temperature",
        "sources": [
          {
            "position": [200, 150],
            "intensity": 400000,
            "radius": 12,
            "falloff": "inverse_square"
          }
        ]
      }
    ]
  },

  "sensors": {
    "heat-sensor": {
      "stimulus_unit": "K",
      "response_function": {
        "type": "triangular",
        "peak_stimulus": 100,
        "max_voltage": 50
      }
    }
  },

