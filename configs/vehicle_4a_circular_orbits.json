{
  "environment": {
    "fields": [
      {
        "type": "temperature",
        "sources": [
          {
            "position": [0, 0],
            "intensity": 2250000,
            "radius": 12,
            "falloff": "inverse_square"
          }
        ]
      }
    ]
  },

